<html>
<head>
    <link crossorigin="anonymous" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
          integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/viewFocusedRead.css">
</head>
<body>
<div id="content">
    <div class="container">
        <div id="row1" class="row">
            header
        </div>
        <div id="row2" class="row">
            <div id="row2col1" class="col col">
                <div id="article-title" class="row">
                    {{ .article.Title }}
                </div>
                <div id="article-content" class="row">
                    {{ .article.Content }}
                </div>
                <div id="row2col1row3" class="row">
                    <div id="row2col1row3col1" class="col col-2">
                        <img id="arrow-previous" src="/static/icons/arrow-previous.svg" alt="Next">
                    </div>
                    <div id="place-holder" class="col col-6">
                        place holder
                    </div>
                    <div id="row2col1row3col3" class="col col-4">
                        <img id="arrow-next" src="/static/icons/arrow-next.svg" alt="Next">
                    </div>
                </div>
            </div>
            <div id="row2col2" class="col col-4">
                 {{range .lookups}}
                     {{.Hanzi}}
                     {{.Pinyin}}
                     {{.CnLookup}}
                     {{.EnLookup}}
                     <br>
                 {{ end}}
            </div>
        </div>

    </div>
</div>
</body>
</html>