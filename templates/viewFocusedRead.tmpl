<html>
<head>
    <link crossorigin="anonymous" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
          integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" rel="stylesheet">
</head>
<body style="background-color:#ededf0">
<div id="content" style="margin-top:20px; margin-left:40px; margin-right:40px;margin-bottom:40px">
    <div class="container style=">
        <div class="row" style="background-color:yellow; height:40px;width:1200px;">
            header
        </div>
        <div class="row" style="background-color:orange;height:600px;width:1200px;">
            <div class="col col" style="background-color:cadetblue;width:400px;">
                <div class="row" style="background-color:indianred;height:100px;">
                    {{ .article.Title }}
                </div>
                <div class="row" style="background-color:yellow;height:400px;">
                    {{ .article.Content }}
                </div>
                <div class="row" style="background-color:greenyellow;height:100px;">
                    <div class="col col-2" style="background-color:palevioletred;">
                        left arrow
                    </div>
                    <div class="col col-6" style="background-color:blue;">
                        place holder
                    </div>
                    <div class="col col-4" style="background-color:palevioletred;">
                        right arrow
                    </div>
                </div>
            </div>
            <div class="col col-4" style="background-color:antiquewhite;">
                dictionary
            </div>
        </div>

    </div>
</div>
</body>
</html>